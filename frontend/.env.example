# Local dev: leave VITE_API_URL unset so Vite proxies to the API (see vite.config.ts).
#
# Vercel / production build: set in the Vercel project → Settings → Environment Variables
# (Production + Preview as needed). Example:
#   VITE_API_URL=https://healthcareapi.culturemind.org
#
# VITE_API_URL=

# Optional: override proxy target when running npm run dev
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
