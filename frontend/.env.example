# API + WebSocket base.
#
# Dev (recommended): leave VITE_API_URL unset so the UI talks to the Vite dev server and it
# proxies to the API — same site as the SPA, so cookie sessions (SameSite=Lax) work from
# both http://localhost:5173 and http://127.0.0.1:5173.
#
# If you set VITE_API_URL, use a host that matches your browser URL (localhost vs 127.0.0.1),
# or cookies will not be sent on fetch and /auth/me returns 401 after login.
#
# VITE_API_URL=http://127.0.0.1:8000
#
# Where uvicorn listens when using the dev proxy (default matches typical local run):
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
#
# Ensure Postgres is up (e.g. docker compose up -d in repo root) and run alembic upgrade head.
