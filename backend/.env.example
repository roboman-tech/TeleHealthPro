APP_NAME=TeleHealthPro API
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telehealthpro

JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

FHIR_BASE_URL=
FHIR_TOKEN=

# All browser origins allowed to call the API (JSON list). Add your Vercel URL(s), e.g.:
#   "https://your-app.vercel.app","https://your-custom-domain.com"
# Local dev entries + production SPA:
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175","http://localhost:3000"]
# Join links and redirects: must match the URL users open for the SPA (Vercel production URL).
FRONTEND_BASE_URL=http://localhost:5173

# Local default is lax + insecure cookies. For split HTTPS deploy (Vercel SPA + API on this host), set:
#   SESSION_COOKIE_SAME_SITE=none
#   SESSION_COOKIE_SECURE=true

# Video: default is public Jitsi; use your own Meet URL in production
JITSI_BASE_URL=https://meet.jit.si

# create_admin.py — first run: set ADMIN_PASSWORD. If admin exists: sign in, or reset with:
# ADMIN_FORCE_RESET=1
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# ADMIN_NAME=System Admin
